    "ajv": "^8.18.0",
    "better-sqlite3": "^12.1.1",
    "fastify": "^5.8.3",
    "fastify-plugin": "^5.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
